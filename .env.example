# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stopmap
POSTGRES_USER=stopmap_user
POSTGRES_PASSWORD=change_me                          # min 20 chars recommended

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000                        # internal endpoint (used by backend)
MINIO_PUBLIC_ENDPOINT=localhost:9000                 # public-facing endpoint (for presigned URLs)
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me                           # min 32 chars recommended
MINIO_BUCKET=stopmap-photos
MINIO_USE_SSL=false                                  # set true in production with TLS

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather     # get from @BotFather

# First admin bootstrap (used only on first startup if no admin exists)
FIRST_ADMIN_PHONE=+77000000000
FIRST_ADMIN_NAME=Admin
FIRST_ADMIN_PASSWORD=change_me                       # min 16 chars recommended

# App
APP_ENV=production                                   # development | production
SECRET_KEY=change_me                                 # 64 hex chars: python3 -c "import secrets; print(secrets.token_hex(32))"
CORS_ORIGINS=https://yourdomain.com                  # comma-separated list of allowed origins

# Docker images (for docker-compose.prod.yml — set your GitHub username)
BACKEND_IMAGE=ghcr.io/karl4th/stopmap-backend:latest
FRONTEND_IMAGE=ghcr.io/karl4th/stopmap-frontend:latest
TELEGRAM_IMAGE=ghcr.io/karl4th/stopmap-telegram:latest
